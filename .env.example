NEWAPI_BASE_URL=
NEWAPI_KEY=
NEWAPI_MODEL=gemini-3.1-pro-preview
YUNWU_BASE_URL=https://yunwu.ai/v1
YUNWU_API_KEY=
YUNWU_GEMINI_API_KEY=

# 原生联网搜索（可选）
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_API_KEY=
DATABASE_URL=

# 可选：向量 RAG（推荐 text-embedding-3-large + pgvector）
RAG_ENABLED=false
RAG_OPENAI_BASE_URL=https://api.openai.com/v1
RAG_OPENAI_API_KEY=
RAG_EMBEDDING_MODEL=text-embedding-3-large
RAG_EMBEDDING_DIMENSIONS=1024
RAG_TOP_K=6
RAG_MIN_SIMILARITY=0.55
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=140

WIKI_ADMIN_TOKEN=

# 主站 SSO
MAIN_APP_URL=
MAIN_APP_KB_CHAT_ENTRY_PATH=/bot/kb-chat
MAIN_APP_KB_CHAT_SSO_EXCHANGE_PATH=/api/kb-chat-sso/exchange
# 本地开发可改为 false，正式环境建议保持 true
REQUIRE_MAIN_APP_SSO=false
KB_CHAT_SESSION_SECRET=
KB_CHAT_SESSION_COOKIE_NAME=kb_chat_session
KB_CHAT_SESSION_TTL_MINUTES=720
